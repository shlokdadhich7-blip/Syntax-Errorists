rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions - Modified for Prototype (Allows mock user access)
    function isSignedIn() {
      return true; // Simplified for demo/prototype to bypass restriction
    }
    
    function isOwner(userId) {
      return true; // Trusting client-side user switching for this prototype
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
        request.resource.data.userId == resource.data.userId;
      
      function isValidUser(data) {
        return data.keys().hasAll(['userId', 'name', 'landOwned', 'annualIncome']) &&
               data.userId is string && data.name is string && data.name.size() > 0 &&
               data.landOwned is number && data.annualIncome is number;
      }
    }

    // Loan Application Rules
    match /loans/{loanId} {
      allow get, list: if true; 
      allow create: if isValidLoan(request.resource.data);
      allow update: if (
        // Allow update if status is Submitted
        (resource.data.status == "Submitted" && isValidLoan(request.resource.data))
      );

      function isValidLoan(data) {
        return data.userId is string && data.status in ["Submitted", "Verification", "Inspection", "Approval", "Disbursement"];
      }
    }

    // EMI Schedule Rules
    match /emiSchedules/{scheduleId} {
      allow get, list: if true;
      allow create: if true; 
      allow update: if true;
    }
  }
}
